<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETTINGS"
            android:textSize="11sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎙 Sender"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure on the phone that streams audio"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio Port"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etAudioPort"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="5"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 9999"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buffer Multiplier"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Multiplied against minimum audio buffer. Higher = more stable, more latency."
                android:textSize="10sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etBufferMultiplier"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="2"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 2"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎧 Receiver"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure on the phone that plays audio"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Timeout (seconds)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etScanTimeout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="3"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 8"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connection Retry Count"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRetryCount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="3"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 10"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry Delay (seconds)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRetryDelay"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="3"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 2"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔗 Shared"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Must match on both phones"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discovery Port"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDiscoveryPort"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:maxLength="5"
                android:background="#2A2A2A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Default: 9998"
                android:hintTextColor="#555555" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Settings"
            android:textSize="16sp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnResetSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Reset to Defaults"
            android:textSize="14sp"
            android:backgroundTint="#2A2A2A"
            android:textColor="#888888"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvSettingsSaved"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ Settings saved"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
